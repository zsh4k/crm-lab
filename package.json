{
  "name": "crm",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "CRM ligero y moderno: clientes/prospectos, inventario y agenda sincronizable con Google Calendar. Bun + Hono + Drizzle + PostgreSQL.",
  "scripts": {
    "dev:api": "bun --watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "start": "bun run src/server/index.ts",
    "test": "CRM_ENC_KEY=test-key-0123456789abcdef bun test"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "postgres": "^3.4.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.3",
    "@types/web-push": "^3.6.4",
    "bun-types": "^1.1.42",
    "drizzle-kit": "^0.28.1",
    "preact": "^10.25.4",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
