# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_dev
POSTGRES_DB=crm
DATABASE_URL=postgresql://crm:crm_dev@crm-postgres:5432/crm

# ── Server ─────────────────────────────────────────────────
PORT=3210
# URL pública desde donde se sirve la app (para armar el redirect de Google).
APP_BASE_URL=https://crm.codex.bunx.monster

# ── Cifrado de tokens OAuth (AES-256-GCM) ──────────────────
# Genera una clave fuerte:  openssl rand -base64 48
CRM_ENC_KEY=cambia-esto-por-una-clave-larga-y-secreta

# ── Google Calendar OAuth2 ─────────────────────────────────
# Crea un "OAuth client ID" tipo Web application en Google Cloud Console,
# habilita la Google Calendar API, y registra el redirect URI de abajo.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://crm.codex.bunx.monster/api/google/callback

# ── Sync ───────────────────────────────────────────────────
# Cada cuánto el worker hace pull/push contra Google (ms). Default 2 min.
SYNC_POLL_INTERVAL_MS=120000

# ── Web Push (recordatorios de citas) ──────────────────────
# Genera las claves:  bunx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@bunx.monster
# Minutos de anticipación del recordatorio antes de que arranque el evento.
REMINDER_LEAD_MIN=10
